DATABASE_URL=postgres://repos:repos_dev_pw@192.168.88.2:5432/repos
PORT=3001
HOST=127.0.0.1
# ADMIN_API_KEY=  # Leave unset for local dev. Required when NODE_ENV=production.

# Cloudflare Access whole-host auth. CF_ACCESS_ENABLED gates the feature
# entirely; until set to 'true', /api/me returns 503 and the bearer-or-cf-access
# composer falls back to bearer-only.
# CF_ACCESS_ENABLED=false
# CF_ACCESS_TEAM_DOMAIN=jpmtech.cloudflareaccess.com
# CF_ACCESS_AUD=                              # Application Audience Tag from CF dashboard
# CF_ACCESS_ALLOWED_EMAILS=jason@jpmtech.com  # Defense-in-depth allowlist (comma-separated)

# Per D10: admin gate for /api/tokens (and any other requireAdminKeyOrCfAccess
# route) on the CF Access cookie path. Comma-separated, case-insensitive list
# of email claims permitted to act as admin. Fails closed (403
# admin_check_misconfigured) when unset and CF Access is in use. Migration 063
# reserves users.role TEXT for the post-Beta cohort scale-up.
# REPOS_ADMIN_EMAILS=admin@example.com

# Per C-CSRF-ORIGIN: the canonical browser origin (scheme + host + port) for
# the SPA. Used by the csrfOrigin preHandler to gate state-changing routes on
# the CF Access cookie path. Fail-closed (403 csrf_origin_misconfigured) when
# unset.
# PUBLIC_ORIGIN=https://repos.jpmtech.com

# W5 — Healthchecks.io alert pings (per Appendix A ABS-5). Optional: alerting,
# not gating. Provision two checks in Healthchecks.io and paste UUIDs here:
#   - HEALTHCHECKS_BACKUP_UUID — cron mode, 1 day period, 30 min grace.
#     repos-backup.sh pings this on success. No ping in 24h+30m = alert.
#   - HEALTHCHECKS_HEALTH_UUID — cron mode, 10 min period, 5 min grace.
#     Unraid host cron pings this from outside the container every 10m.
# HEALTHCHECKS_BACKUP_UUID=
# HEALTHCHECKS_HEALTH_UUID=

# W5 — restore-flow paths. Defaults match the in-container layout; override
# only for local/dev. SHUTDOWN_TIMEOUT_MS drives the SIGTERM graceful drain.
# MAINTENANCE_FLAG_PATH=/config/maintenance.flag
# RESTORE_STATE_PATH=/config/restore-state.json
# BACKUPS_DIR=/config/backups
# SHUTDOWN_TIMEOUT_MS=30000
# In the production container, operational scripts are COPYed to /scripts and
# the API to /app/api — set these so restoreRunner.ts spawn-detaches the right
# run-restore.sh (the code default is /app/scripts for local dev):
# REPOS_SCRIPTS_DIR=/scripts
# REPOS_API_DIR=/app/api
