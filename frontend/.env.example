# Frontend → API base URL.
# - Dev: set to http://localhost:3001 (cross-origin; requires the dev API to
#   send CORS headers including Access-Control-Allow-Credentials for cookie auth).
# - Prod: leave empty (`VITE_API_URL=`) so /api/* resolves same-origin via nginx.
#   Same-origin is required for the CF Access cookie to be sent automatically.
VITE_API_URL=http://localhost:3001

# Beta landmarks-editor gate (read in SettingsProgramPrefsPage). Defaults to
# 'on' when unset; set to 'off' to hide the volume-landmarks editor.
# VITE_BETA_LANDMARKS_EDITOR=on
